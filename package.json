{
    "name": "rpa-extension-monorepo",
    "private": true,
    "packageManager": "pnpm@10.28.0",
    "scripts": {
        "dev:agent": "pnpm --filter ./agent dev:hot",
        "dev:cdp": "pnpm build:extension && pnpm --filter ./agent dev:cdp",
        "dev:mcp": "pnpm --filter ./agent mcp:hot",
        "build:extension": "pnpm --filter ./extension build && pnpm --filter ./start_extension build",
        "dev": "pnpm build:extension && pnpm dev:agent",
        "mock:dev": "node mock/server.js",
        "mcp:demo": "pnpm --filter ./agent mcp:demo",
        "mcp": "pnpm --filter ./agent mcp",
        "mcp:hot": "pnpm --filter ./agent mcp:hot",
        "setup": "pnpm -r install && pnpm exec playwright install chromium",
        "pw:install": "pnpm --filter ./agent exec playwright install chromium",
        "test:agent": "pnpm --filter ./agent test",
        "test:agent:entity-rules": "pnpm --filter ./agent test:entity-rules",
        "test:agent:headed": "pnpm --filter ./agent test:headed",
        "test:agent:smoke:mcp": "pnpm --filter ./agent test:smoke:mcp",
        "test:extension": "pnpm --filter ./extension test",
        "typecheck:agent": "pnpm --filter ./agent typecheck",
        "typecheck:extension": "pnpm --filter ./extension exec tsc --noEmit",
        "typecheck": "pnpm typecheck:agent && pnpm typecheck:extension",
        "lint": "npx eslint \"**/*.{ts,tsx,js,jsx}\" --ext .ts,.tsx,.js --max-warnings=0",
        "format": "npx prettier --write \"**/*.{ts,tsx,js,jsx,css,md,json,html}\""
    },
    "devDependencies": {
        "@types/node": "^22.19.7",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.54.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^4.2.1",
        "prettier": "^2.8.8",
        "playwright": "^1.57.0"
    }
}
