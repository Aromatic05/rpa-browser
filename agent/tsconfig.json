{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "types": ["node"],
        "resolveJsonModule": true
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"],
    "exclude": ["src/**/__tests__/**/*.ts"]
}
