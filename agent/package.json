{
    "name": "rpa-agent",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "tsx src/index.ts",
        "dev:cdp": "RPA_BROWSER_MODE=cdp tsx src/index.ts",
        "dev:watch": "tsx watch src/index.ts",
        "dev:hot": "concurrently -k \"pnpm test:runner:bundle:watch\" \"pnpm dev\"",
        "mcp:demo": "tsx src/demo/server.ts",
        "mcp": "tsx src/mcp_main.ts",
        "mcp:dev": "tsx watch src/mcp_main.ts",
        "mcp:hot": "concurrently -k \"pnpm test:runner:bundle:watch\" \"pnpm mcp:dev\"",
        "control": "tsx src/control_cli.ts",
        "test:runner:bundle": "esbuild src/runner/plugin_entry.ts --bundle --format=esm --platform=node --packages=external --outfile=.runner-dist/plugin.mjs --sourcemap",
        "test:runner:bundle:watch": "esbuild src/runner/plugin_entry.ts --bundle --format=esm --platform=node --packages=external --outfile=.runner-dist/plugin.mjs --sourcemap --watch",
        "test:unit": "node --import tsx --test \"tests/integration/config/**/*.test.ts\" \"tests/integration/control/**/*.test.ts\" \"tests/integration/dsl/**/*.test.ts\" \"tests/integration/mcp/**/*.test.ts\" \"tests/integration/runner/checkpoint/**/*.test.ts\" \"tests/integration/runner/hotreload/**/*.test.ts\" \"tests/integration/runner/steps/**/*.test.ts\" \"tests/integration/runner/trace/runtime/**/*.test.ts\" tests/integration/protocol_stream.test.ts",
        "test:integration:run": "pnpm test:runner:bundle && pnpm -C .. build:extension && node --import tsx --test --test-concurrency=1 \"tests/integration/**/*.test.ts\"",
        "test:integration": "RPA_INTEGRATION_HEADED=false pnpm test:integration:run",
        "test:integration:headed": "RPA_INTEGRATION_HEADED=true pnpm test:integration:run",
        "test:e2e": "RPA_E2E_HEADED=0 pnpm test:e2e:run",
        "test:runner": "node --import tsx --test \"tests/integration/runner/**/*.test.ts\"",
        "test:trace": "node --import tsx --test \"tests/integration/trace/**/*.test.ts\"",
        "test:entity-rules": "node --import tsx --test \"tests/integration/entity_rules/**/*.test.ts\"",
        "test:smoke:mcp": "tsx scripts/mcp_smoke_client.ts",
        "test:unit:keyslot": "SNAPSHOT_KEYSLOT_DATASET=1 node --import tsx --test tests/integration/runner/steps/snapshot_keyslot_dataset.test.ts",
        "test:unit:snapshot:perf": "SNAPSHOT_PERF_BASELINE=1 node --import tsx --test tests/integration/runner/steps/snapshot_performance_baseline.test.ts",
        "snapshot:bulk:collect": "tsx scripts/snapshot_bulk_collect.ts",
        "snapshot:keyslot:eval": "tsx scripts/snapshot_eval_keyslot.ts",
        "snapshot:accept:ant-table": "tsx scripts/snapshot_accept_ant_table.ts",
        "test:all": "pnpm test:e2e && pnpm test:runner && pnpm test:trace && pnpm test:unit",
        "test:ci": "pnpm test:runner && pnpm test:trace && pnpm test:unit && pnpm test:integration",
        "typecheck": "tsc --noEmit",
        "pw:install": "pnpm exec playwright install chromium",
        "test": "pnpm test:all",
        "test:headed": "playwright test tests/e2e --pass-with-no-tests --headed",
        "test:e2e:run": "pnpm test:runner:bundle && pnpm -C .. build:extension && playwright test tests/e2e",
        "test:e2e:headed": "RPA_E2E_HEADED=1 pnpm test:e2e:run --headed"
    },
    "dependencies": {
        "@axe-core/playwright": "^4.10.2",
        "@modelcontextprotocol/sdk": "1.0.0",
        "chokidar": "^3.6.0",
        "playwright": "^1.57.0",
        "ws": "^8.19.0",
        "yaml": "2.8.1",
        "zod": "3.23.8"
    },
    "devDependencies": {
        "@playwright/test": "^1.57.0",
        "@types/node": "^22.19.18",
        "@types/ws": "^8.5.10",
        "concurrently": "^9.2.1",
        "esbuild": "^0.25.0",
        "tsx": "^4.20.5",
        "typescript": "^5.9.2"
    }
}
