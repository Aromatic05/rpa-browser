{
  "name": "@mock/workspace",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --filter @mock/ant-app exec vite --host 127.0.0.1 --port 5173 --strictPort & pnpm --filter @mock/element-app exec vite --host 127.0.0.1 --port 5174 --strictPort",
    "dev:ant": "pnpm --filter @mock/ant-app exec vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:element": "pnpm --filter @mock/element-app exec vite --host 127.0.0.1 --port 5174 --strictPort",
    "build": "pnpm -r build",
    "preview:ant": "pnpm --filter @mock/ant-app preview",
    "preview:element": "pnpm --filter @mock/element-app preview"
  }
}
